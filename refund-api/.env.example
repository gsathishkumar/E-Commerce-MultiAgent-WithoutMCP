# ============================================================
# Refunds API — environment configuration
# Copy to .env and fill in your values.
# All variables are optional; defaults shown below.
# ============================================================

# ----------------------------------------------------------
# Application
# ----------------------------------------------------------
APP_NAME=Refunds API
APP_VERSION=1.0.0

# Runtime environment: development | staging | production
APP_ENVIRONMENT=development

# Enable FastAPI debug mode (verbose error pages)
DEBUG=false

# ----------------------------------------------------------
# API
# ----------------------------------------------------------
API_V1_PREFIX=/refund-api/api/v1

# ----------------------------------------------------------
# MongoDB
# ----------------------------------------------------------
MONGO_DB_HOST=localhost
MONGO_DB_PORT=27017
MONGO_DB_USER=ecommerce_user
MONGO_DB_PASSWORD=ecommerce_pwd
MONGO_DB_NAME=ecommerce_db

# Collection that stores return/refund documents
MONGO_REFUNDS_COLLECTION=refunds

# Timeout values (milliseconds)
MONGO_CONNECT_TIMEOUT_MS=5000
MONGO_SERVER_SELECTION_TIMEOUT_MS=5000
