# Copy this to .env and adjust values as needed

APP_NAME="Product RAG API"
APP_VERSION="1.0.0"
DEBUG=false

UPLOAD_DIR=uploads
MAX_FILE_SIZE_BYTES=1048576

# PostgreSQL connection
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=ragdb
POSTGRES_USER=product_user
POSTGRES_PASSWORD=password123

# Worker threads
MAX_WORKERS=4

# Chunking
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# Embedding model
EMBEDDING_MODEL="text-embedding-3-small"
EMBEDDING_DIMENSION=1024

# Retrieval
TOP_K_RESULTS=5

# pgvector index type: "hnsw" (recommended) or "ivfflat"
PGVECTOR_INDEX_TYPE=hnsw

OPENAI_API_KEY=sk-<your-OPENAI_API_KEY-here>